# ═══════════════════════════════════
# Saiyan Protocol API — Environment
# ═══════════════════════════════════

# Server
PORT=3001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saiyan_protocol

# JWT
JWT_SECRET=change-this-to-a-real-secret
JWT_EXPIRES_IN=7d

# Firebase (project ID — token verification uses firebase-admin)
FIREBASE_PROJECT_ID=saiyan-protocol
# Optional: path to service account key for local dev
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# AI Provider (TBD — plug in OpenAI, Anthropic, etc.)
AI_PROVIDER=stub
AI_API_KEY=
AI_MODEL=
